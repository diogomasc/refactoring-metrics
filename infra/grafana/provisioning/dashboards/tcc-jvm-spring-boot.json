{
  "__inputs": [],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel",      "id": "timeseries", "name": "Time series","version": "" },
    { "type": "panel",      "id": "stat",       "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "gauge",      "name": "Gauge",      "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "JVM, threads, GC e uso de CPU/memória do protótipo Spring Boot — gerado via provisioning automático.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "📊 Visão Geral da JVM",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s", "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 201,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_uptime_seconds{job=\"spring-boot-prototipo\"}",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 256 }, { "color": "red", "value": 384 }] },
          "unit": "decmbytes", "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 202,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "Heap Usado (MB)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"spring-boot-prototipo\"} / 1024 / 1024",
          "legendFormat": "heap_used_mb",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] },
          "unit": "short", "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 203,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "Threads Ativas",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_live_threads{job=\"spring-boot-prototipo\"}",
          "legendFormat": "threads_live",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 80 }] },
          "unit": "percent", "min": 0, "max": 100, "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 204,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "CPU do Processo (%)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_usage{job=\"spring-boot-prototipo\"} * 100",
          "legendFormat": "cpu_usage",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] },
          "unit": "ops", "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 205,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "title": "GC — Pauses (ops/s)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(jvm_gc_pause_seconds_count{job=\"spring-boot-prototipo\"}[1m]))",
          "legendFormat": "gc_ops",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 210,
      "title": "🧠 Memória JVM",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decmbytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "id": 211,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Heap — Usado vs Comprometido (MB)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=\"spring-boot-prototipo\"} / 1024 / 1024",
          "legendFormat": "heap_used  ({{ id }})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_committed_bytes{area=\"heap\", job=\"spring-boot-prototipo\"} / 1024 / 1024",
          "legendFormat": "heap_committed  ({{ id }})",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_max_bytes{area=\"heap\", job=\"spring-boot-prototipo\"} / 1024 / 1024",
          "legendFormat": "heap_max  ({{ id }})",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "decmbytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "id": 212,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Non-Heap — Usado vs Comprometido (MB)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_used_bytes{area=\"nonheap\", job=\"spring-boot-prototipo\"} / 1024 / 1024",
          "legendFormat": "nonheap_used  ({{ id }})",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_memory_committed_bytes{area=\"nonheap\", job=\"spring-boot-prototipo\"} / 1024 / 1024",
          "legendFormat": "nonheap_committed  ({{ id }})",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 220,
      "title": "🔄 Threads & GC",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "id": 221,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Threads JVM (live / daemon / peak)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_live_threads{job=\"spring-boot-prototipo\"}",
          "legendFormat": "live",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_daemon_threads{job=\"spring-boot-prototipo\"}",
          "legendFormat": "daemon",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_peak_threads{job=\"spring-boot-prototipo\"}",
          "legendFormat": "peak",
          "refId": "C"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "id": 222,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "GC — Tempo Total de Pausa (s/min)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_sum{job=\"spring-boot-prototipo\"}[1m]))",
          "legendFormat": "{{ action }} / {{ cause }}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 230,
      "title": "⚙️ CPU",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "min": 0, "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 231,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU — Processo vs Sistema",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_usage{job=\"spring-boot-prototipo\"}",
          "legendFormat": "processo",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_cpu_usage{job=\"spring-boot-prototipo\"}",
          "legendFormat": "sistema",
          "refId": "B"
        }
      ]
    }

  ],

  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["tcc", "spring-boot", "jvm", "micrometer"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TCC — JVM & Runtime (Spring Boot)",
  "uid": "tcc-jvm-spring-boot",
  "version": 1
}
